{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadInstanceAndSecurityGroups",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeSecurityGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReplaceInstanceSecurityGroups",
      "Effect": "Allow",
      "Action": "ec2:ModifyInstanceAttribute",
      "Resource": "arn:aws:ec2:*:*:instance/*"
    }
  ]
}
