{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublishIncidentNotification",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "arn:aws:sns:*:*:aws-ir-*"
    },
    {
      "Sid": "UseIncidentTopicKey",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:*:*:key/*"
    }
  ]
}
